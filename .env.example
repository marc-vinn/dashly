# ─── Dashly — Variáveis de Ambiente ───
# Copie este arquivo para .env e preencha com suas chaves reais.
# NUNCA commite o .env com valores reais.

# OpenRouter API Key (necessária para o AI Assistant na aba Análises)
OPENROUTER_API_KEY=sua_chave_aqui

# Modelo do OpenRouter a ser utilizado (padrão é o deepseek-v4-flash gratuito)
# Você pode alterar para outros modelos gratuitos da OpenRouter se o principal estiver congestionado.
# Opções gratuitas recomendadas:
# - deepseek/deepseek-v4-flash:free (Padrão)
# - meta-llama/llama-3-8b-instruct:free
# - google/gemini-2.5-flash:free
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

